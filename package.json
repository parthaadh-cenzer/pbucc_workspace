{
  "name": "team-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run prisma:verify-postgres && prisma generate && npm run prisma:migrate:deploy:if-vercel && next build",
    "build:vercel": "npm run prisma:verify-postgres && prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:verify-postgres": "node scripts/verify-prisma-postgres.cjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy:if-vercel": "node scripts/prisma-migrate-if-vercel.cjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "docx": "^9.6.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "next": "16.2.2",
    "next-auth": "^4.24.13",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
